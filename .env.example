# ====================================
# 以下は管理者が設定します。
# 講師は編集不要です。
# ====================================

# Cognito認証
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_DOMAIN=auth.aione.co.jp

# ONEグループ基盤API
NEXT_PUBLIC_API_BASE_URL=https://api.aione.co.jp
NEXT_PUBLIC_TOOL_ID=ここにツールIDが入ります

# ====================================
# MCP（開発支援ツール）専用環境変数
# ====================================

# ONEグループ基盤 中央 tool_data API は Cognito ID Token (Bearer) 認証必須。
# MCP（Node.js stdio subprocess）はブラウザのCognito SSOが使えないため、
# user 自身の ID Token を `.env.local` に下記の名前で export する。
#
# 取得方法（README 参照）:
#   1. https://tools.aione.co.jp/ にブラウザログイン
#   2. DevTools → Application → Cookies → `one_id_token` の値をコピー
#   3. `.env.local` に下記の形式で貼り付け（クォート不要）
#
# TTL: 1時間。期限切れで 401 が返ったら再ログインしてトークンを更新。
# 未設定の場合、Authorization ヘッダー無しでリクエストされ、サーバー側で 401 となる。
ONE_GROUP_BEARER_TOKEN=
